# ─────────────────────────────────────────────────────────────────────────────
# CoFound — environment variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Auth approach: claude setup-token ────────────────────────────────────────
# Users generate a 1-year OAuth bearer token by running:
#   claude setup-token
# in their terminal (requires Claude Code CLI + Max plan).
# The token is pasted into the CoFound login UI and stored in a session cookie.
# No OAuth app registration needed.
#
# For local dev/testing you can optionally set CLAUDE_CODE_OAUTH_TOKEN here
# instead of going through the UI each time:
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...

# ── Classic API key (fallback for local dev without a claude setup-token) ─────
# If no session token is found, the API route falls back to this key.
# Leave blank in production.
ANTHROPIC_API_KEY=sk-ant-...
